---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resume" description="Alexander Tian's resume.">
  <h1>Resume</h1>

  <p>
    You can <a href="/resume.pdf">download my resume here</a> (PDF).
  </p>

  <p class="muted">A preview is embedded below.</p>

  <iframe
    src="/resume.pdf"
    title="Alexander Tian — resume"
    style="width: 100%; height: 80vh; border: 1px solid var(--border); margin-top: 1rem; display: block;"
  ></iframe>
</BaseLayout>
